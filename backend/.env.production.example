ENVIRONMENT=production

# Supabase recomendado para Render: Session pooler.
# Copiar desde Supabase > Connect y reemplazar PASSWORD.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Obligatorio en produccion. Usar un valor largo y secreto.
# El backend lee JWT_SECRET_KEY, no SECRET_KEY.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL publica del backend desplegado.
API_PUBLIC_URL=https://tu-servicio.onrender.com

# URL donde se sirve el frontend. Si lo sirve el mismo backend, usar el mismo dominio.
FRONTEND_PUBLIC_URL=https://tu-servicio.onrender.com

# Origenes permitidos para llamadas desde navegador, separados por coma.
CORS_ORIGINS=https://tu-servicio.onrender.com

CREATE_INITIAL_ADMIN=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
INITIAL_ADMIN_FULL_NAME=Administrador
INITIAL_ADMIN_EMAIL=admin@example.com

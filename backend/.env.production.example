ENVIRONMENT=production

# Render/Railway suelen inyectar DATABASE_URL desde el servicio de base de datos.
# SQLite funciona para pruebas simples, pero no es durable en la mayoria de hosts.
DATABASE_URL=postgres://user:password@host:5432/database

# Obligatorio en produccion. Usar un valor largo y secreto.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL publica del backend desplegado.
API_PUBLIC_URL=https://rastreo-backend.example.com

# URL donde se sirve el frontend si esta separado del backend.
FRONTEND_PUBLIC_URL=https://rastreo-frontend.example.com

# Origenes permitidos para llamadas desde navegador, separados por coma.
CORS_ORIGINS=https://rastreo-frontend.example.com

CREATE_INITIAL_ADMIN=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
INITIAL_ADMIN_FULL_NAME=Administrador
INITIAL_ADMIN_EMAIL=admin@example.com

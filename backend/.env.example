ENVIRONMENT=local

# Local por defecto: SQLite.
DATABASE_URL=sqlite:///./rastreo.db

JWT_SECRET_KEY=change-me-local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local frontend origins allowed to call the API when opened from another server.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500
API_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:8000

CREATE_INITIAL_ADMIN=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_FULL_NAME=Administrador
INITIAL_ADMIN_EMAIL=admin@example.com

# Produccion en Render/Supabase:
# - no usar secretos reales en este archivo
# - configurar estas variables en el panel Environment de Render
# - el backend lee JWT_SECRET_KEY, no SECRET_KEY
#
# ENVIRONMENT=production
# DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# JWT_SECRET_KEY=replace-with-a-long-random-secret
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# CREATE_INITIAL_ADMIN=true
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
